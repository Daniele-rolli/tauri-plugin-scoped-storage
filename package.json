{
  "name": "tauri-plugin-scoped-storage-api",
  "version": "0.1.0",
  "author": "Daniele Rolli",
  "description": "Guest-side bindings for the Tauri scoped storage plugin",
  "license": "MIT",
  "type": "module",
  "types": "./dist-js/index.d.ts",
  "main": "./dist-js/index.cjs",
